{

  /* Vertical guidelines for line wrapping. */
  "editor.rulers": [
    80,
    100,
    120,
  ],

  /* By default, wrap long lines at the viewport or 120 characters,
  whichever is narrowest. */
  "editor.wordWrap": "bounded",
  "editor.wordWrapColumn": 120,

  "[asciidoc]": {
    /* Wrap AsciiDoc files at 72 characters. */
    "editor.wordWrap": "bounded",
    "editor.wordWrapColumn": 72,

    /* Enable auto-formatting for Asciidoc files. */
    "editor.formatOnPaste": true,
    "editor.formatOnSave": true,
    "editor.formatOnType": true,

    /* Enable auto-fixes for Asciidoc files. */
    "editor.codeActionsOnSave": {
      "source.fixAll": "always",
    },
  },

  "[markdown]": {
    /* Wrap Markdown files at 72 characters. */
    "editor.wordWrap": "bounded",
    "editor.wordWrapColumn": 72,

    /* Enable auto-formatting for Markdown files. */
    "editor.formatOnPaste": true,
    "editor.formatOnSave": true,
    "editor.formatOnType": true,

    /* Enable auto-fixes for Markdown files. */
    "editor.codeActionsOnSave": {
      "source.fixAll": "always",
    },
  },

  "[python]": {
    /* Python files should wrap at 88 characters. */
    "editor.rulers": [
      88
    ],
    "editor.wordWrap": "bounded",
    "editor.wordWrapColumn": 88,

    /* Enable auto-formatting for Python files. */
    "editor.formatOnPaste": true,
    "editor.formatOnSave": true,
    "editor.formatOnType": true,
  },

  "[skill]": {
    /* Same as Markdown. */
    "editor.wordWrap": "bounded",
    "editor.wordWrapColumn": 72,

    "editor.formatOnPaste": true,
    "editor.formatOnSave": true,
    "editor.formatOnType": true,

    "editor.codeActionsOnSave": {
      "source.fixAll": "always",
    },
  },

}
